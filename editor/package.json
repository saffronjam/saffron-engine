{
  "name": "saffron-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "gen:protocol": "bun run scripts/gen-protocol.ts",
    "check": "bun run gen:protocol && tsc --noEmit",
    "build": "bun run gen:protocol && tsc && vite build",
    "format": "oxfmt --write src scripts",
    "format:check": "oxfmt --check src scripts",
    "lint": "oxlint src scripts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "flame-chart-js": "^3.3.0",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "uplot": "^1.6.32",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "typescript": "^5.9.0",
    "vite": "^7.2.0"
  }
}
