{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Saffron Editor",
  "version": "0.1.0",
  "identifier": "dev.saffron.engine.editor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Saffron Editor",
        "width": 1600,
        "height": 900,
        "minWidth": 900,
        "minHeight": 620,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
